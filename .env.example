# ── Gateway ───────────────────────────────────────────────────────────────────
# Port to expose the MCP gateway on the host
GW_PORT=8080

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── 1C Platform ───────────────────────────────────────────────────────────────
# Path to the 1C platform installation on the host (mounted read-only into platform-context)
HOST_PLATFORM_PATH=/opt/1cv8
# Path inside the container to pass to --platform-path
PLATFORM_PATH=/opt/1cv8/x86_64/8.3.27.2074

# ── BSL LSP ───────────────────────────────────────────────────────────────────
# Name of the running mcp-bsl-lsp-bridge container (must be on the same Docker host)
LSP_CONTAINER=mcp-lsp-zup

# ── Timeouts ──────────────────────────────────────────────────────────────────
# Timeout in seconds for 1C query/code execution
ONEC_TIMEOUT=180

# ── Backends ──────────────────────────────────────────────────────────────────
# Comma-separated list of backends to enable.
# Available: onec-toolkit, platform-context, bsl-lsp-bridge
ENABLED_BACKENDS=onec-toolkit,platform-context,bsl-lsp-bridge
