# ── onec-mcp-universal configuration ────────────────────────────────────────

# Gateway port (default: 8080)
# GW_PORT=8080

# Log level: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# ── Linux setup ──────────────────────────────────────────────────────────────

# Path to 1C platform directory on host (mounted into containers)
# HOST_PLATFORM_PATH=/opt/1cv8

# Platform path for platform-context docs server
PLATFORM_PATH=/opt/1cv8/x86_64/8.3.27.2074

# ── Windows setup ────────────────────────────────────────────────────────────

# On Windows ibcmd cannot run inside Linux containers.
# 1. Run on the host:  python tools\export-host-service.py --port 8082 --workspace C:\1c-projects
# 2. Uncomment:
# EXPORT_HOST_URL=http://host.docker.internal:8082

# ── Backends ─────────────────────────────────────────────────────────────────

# Comma-separated list of backends to enable.
# Add test-runner after starting it with: docker compose --profile test-runner up -d
# ENABLED_BACKENDS=onec-toolkit,platform-context,bsl-lsp-bridge,test-runner

# Test runner URL (if test-runner profile is active)
# TEST_RUNNER_URL=http://localhost:8000/sse

# BSL Graph URL (if bsl-graph profile is active)
# BSL_GRAPH_URL=http://localhost:8888
