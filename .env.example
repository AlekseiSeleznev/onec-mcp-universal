# ── onec-mcp-universal configuration ────────────────────────────────────────

# Gateway port (default: 8080)
# GW_PORT=8080

# ── Linux setup ──────────────────────────────────────────────────────────────
# Path to 1C platform on host (mounted into container for ibcmd access)
# HOST_1CV8_PATH=/opt/1cv8
# IBCMD_PATH=/opt/1cv8/x86_64/8.3.27.2074/ibcmd

# ── Windows setup ────────────────────────────────────────────────────────────
# Remove the HOST_1CV8_PATH volume line from docker-compose.yml, then:
# 1. Run: python tools/export-host-service.py --port 8082 --workspace C:\projects
# 2. Set:
# EXPORT_HOST_URL=http://host.docker.internal:8082

# ── 1C Platform path (for platform-context docs server) ──────────────────────
# PLATFORM_PATH=/opt/1cv8/x86_64/8.3.27.2074
